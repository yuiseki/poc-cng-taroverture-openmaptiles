{
  "name": "poc-cng-taroverture-openmaptiles",
  "version": "0.1.1",
  "description": "PoC: merge 6 remote Overture PMTiles into a single OpenMapTiles-schema vector tile on the fly",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "dev": "node --watch --import tsx src/index.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@mapbox/vector-tile": "^1.3.1",
    "fastify": "^4.26.2",
    "pbf": "^3.3.0",
    "pmtiles": "^3.0.6",
    "vt-pbf": "^3.1.3"
  },
  "devDependencies": {
    "@types/mapbox__vector-tile": "^1.3.4",
    "@types/node": "^25.9.1",
    "@types/pbf": "^3.0.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
